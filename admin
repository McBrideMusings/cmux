@command("relay", "Build and run relayd + relay-client (--port PORT --log LEVEL --filter REGEX)")
def cmd_relay(args):
    import threading

    port = "7800"
    log_level = "app"
    filter_pattern = None
    i = 0
    while i < len(args):
        if args[i] == "--port":
            i += 1
            if i >= len(args):
                err("--port requires a value")
                sys.exit(1)
            port = args[i]
        elif args[i] == "--log":
            i += 1
            if i >= len(args):
                err("--log requires a value (app, debug, system, verbose)")
                sys.exit(1)
            log_level = args[i]
        elif args[i] == "--filter":
            i += 1
            if i >= len(args):
                err("--filter requires a regex pattern")
                sys.exit(1)
            filter_pattern = args[i]
        else:
            err(f"Unknown arg: {args[i]}")
            sys.exit(1)
        i += 1

    # Validate log level early
    predicate = log_predicate(log_level)
    formatter = LogFormatter(filter_pattern=filter_pattern)

    # Build relayd
    info("Building relayd...")
    rc = run_cmd("cd relayd && cargo build")
    if rc != 0:
        err("relayd build failed")
        sys.exit(rc)

    # Build relay-client
    info("Building relay-client...")
    rc = run_cmd(
        "xcodebuild -project GhosttyTabs.xcodeproj -scheme relay-client "
        "-configuration Debug -destination 'platform=macOS' build 2>&1 "
        "| tail -5"
    )
    if rc != 0:
        err("relay-client build failed")
        sys.exit(rc)

    # Find the built app
    import json as _json
    settings_proc = subprocess.run(
        "xcodebuild -project GhosttyTabs.xcodeproj -scheme relay-client "
        "-configuration Debug -showBuildSettings -json 2>/dev/null",
        shell=True, capture_output=True, text=True,
    )
    app_path = None
    if settings_proc.returncode == 0:
        try:
            settings = _json.loads(settings_proc.stdout)
            for entry in settings:
                bs = entry.get("buildSettings", {})
                built_dir = bs.get("BUILT_PRODUCTS_DIR", "")
                product = bs.get("FULL_PRODUCT_NAME", "")
                if product == "relay-client.app" and built_dir:
                    app_path = os.path.join(built_dir, product)
                    break
        except (ValueError, KeyError):
            pass

    if not app_path or not os.path.isdir(app_path):
        err("Could not find relay-client.app — try building manually first")
        sys.exit(1)

    os.makedirs(LOG_DIR, exist_ok=True)
    log_fh = open(LOG_FILE, "a")

    def formatted_stream(proc, source):
        """Read lines from proc.stdout, format, and print/log."""
        try:
            for line in proc.stdout:
                terminal, raw = formatter.format_line(source, line)
                if terminal:
                    sys.stdout.write(terminal)
                    sys.stdout.flush()
                if raw:
                    log_fh.write(raw)
                    log_fh.flush()
        except (IOError, ValueError):
            pass

    # Start relayd server
    info(f"Starting relayd on port {port}...")
    server_proc = subprocess.Popen(
        f"./relayd/target/debug/relayd --port {port}",
        shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
        bufsize=1, universal_newlines=True,
    )
    _children.append(server_proc)
    threading.Thread(target=formatted_stream, args=(server_proc, "server"), daemon=True).start()

    # Start relay-client app and stream its os_log output
    info("Launching relay-client...")
    subprocess.Popen(["open", app_path])

    # Use --level debug for debug/verbose tiers, info for app/system
    stream_level = "debug" if log_level in ("debug", "verbose") else "info"

    client_proc = subprocess.Popen(
        ["log", "stream", "--predicate", predicate,
         "--style", "compact", "--color", "always",
         "--level", stream_level],
        stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
        bufsize=1, universal_newlines=True,
    )
    _children.append(client_proc)
    threading.Thread(target=formatted_stream, args=(client_proc, "client"), daemon=True).start()

    ok(f"Both running (log={log_level}). Ctrl+C to stop.")
    print()

    try:
        server_proc.wait()
    except KeyboardInterrupt:
        pass
    finally:
        for p in [server_proc, client_proc]:
            try:
                p.terminate()
                p.wait(timeout=3)
            except (OSError, subprocess.TimeoutExpired):
                try:
                    p.kill()
                except OSError:
                    pass
            if p in _children:
                _children.remove(p)
        # Also quit the app
        subprocess.run(
            ["osascript", "-e",
             'tell application "relay-client" to quit'],
            capture_output=True,
        )
        log_fh.close()
        print()
        info("Relay stopped.")


# --- Inline TUI Menu ---

def _tui_menu():
    """Inline interactive menu for selecting a command."""
    if not sys.stdout.isatty():
        _print_help()
        return

    import tty
    import termios

    items = list(_commands.keys())
    sel = 0
    num = len(items)

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)

    def read_key():
        try:
            tty.setraw(fd)
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                seq = sys.stdin.read(2)
                if seq == "[A": return "up"
                if seq == "[B": return "down"
                return "esc"
            return ch
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

    total_lines = num + 1  # items + footer

    def draw():
        if draw.rendered:
            sys.stdout.write(f"\033[{total_lines}F")
        sys.stdout.write("\033[J")
        for i, name in enumerate(items):
            desc = _commands[name]["desc"]
            if i == sel:
                sys.stdout.write(f"  {C.CYAN}{C.BOLD}> {name:<14}{C.RESET} {desc}\n")
            else:
                sys.stdout.write(f"    {C.DIM}{name:<14}{C.RESET} {desc}\n")
        sys.stdout.write(f"{C.DIM}  [arrows/j/k] navigate  [enter] run  [q] quit{C.RESET}\n")
        sys.stdout.flush()
        draw.rendered = True

    draw.rendered = False
    print(f"{C.BOLD}{PROJECT_NAME}{C.RESET}\n")

    try:
        while True:
            draw()
            key = read_key()
            if key in ("q", "Q", "esc"):
                print()
                return
            elif key in ("up", "k"):
                sel = (sel - 1) % num
            elif key in ("down", "j"):
                sel = (sel + 1) % num
            elif key in ("\r", "\n"):
                sys.stdout.write(f"\033[{total_lines}F\033[J")
                info(f"./admin {items[sel]}")
                print()
                os.makedirs(LOG_DIR, exist_ok=True)
                open(LOG_FILE, "w").close()
                _commands[items[sel]]["func"]([])
                return
    except (KeyboardInterrupt, EOFError):
        print()
        return
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)


def _print_help():
    """Print help text (non-TTY fallback and --help)."""
    print(f"{C.BOLD}{PROJECT_NAME}{C.RESET}")
    print(f"Usage: ./admin <command> [args...]\n")
    print("Commands:")
    for name, cmd_info in _commands.items():
        print(f"  {C.CYAN}{name:<16}{C.RESET} {cmd_info['desc']}")
    print(f"\nRun {C.DIM}./admin{C.RESET} with no args for interactive menu.")


# --- Main ---

def main():
    os.chdir(os.path.dirname(os.path.abspath(__file__)))

    if len(sys.argv) < 2:
        _tui_menu()
        return

    cmd_name = sys.argv[1]
    if cmd_name in ("-h", "--help", "help"):
        _print_help()
        return

    if cmd_name not in _commands:
        err(f"Unknown command: {cmd_name}")
        _print_help()
        sys.exit(1)

    # Clear log file for fresh run
    os.makedirs(LOG_DIR, exist_ok=True)
    open(LOG_FILE, "w").close()

    _commands[cmd_name]["func"](sys.argv[2:])


if __name__ == "__main__":
    main()
