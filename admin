@command("run-relayd", "Build and run relayd server")
def cmd_run_relayd(args):
    import threading

    info("Building and running relayd...")
    rc = run_cmd("cd relayd && cargo build")
    if rc != 0:
        err("Build failed")
        sys.exit(rc)

    port = "7800"
    i = 0
    while i < len(args):
        if args[i] == "--port":
            i += 1
            if i >= len(args):
                err("--port requires a value")
                sys.exit(1)
            port = args[i]
        else:
            err(f"Unknown arg: {args[i]}")
            sys.exit(1)
        i += 1

    info(f"Starting relayd on port {port}...")
    proc = subprocess.Popen(
        f"./relayd/target/debug/relayd --port {port}",
        shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
        bufsize=1, universal_newlines=True,
    )
    _children.append(proc)

    log_fh = open(LOG_FILE, "a")

    def stream():
        try:
            for line in proc.stdout:
                sys.stdout.write(line)
                sys.stdout.flush()
                log_fh.write(line)
                log_fh.flush()
        except (IOError, ValueError):
            pass

    threading.Thread(target=stream, daemon=True).start()

    try:
        proc.wait()
    except KeyboardInterrupt:
        proc.terminate()
    finally:
        _children.remove(proc)
        log_fh.close()


